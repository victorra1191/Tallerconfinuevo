{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin/(.*)",
      "destination": "backend/server.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "backend/server.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/([^.]*)",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
