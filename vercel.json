{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "backend/server.py"
    },
    {
      "src": "/api/seed-db",
      "dest": "backend/server.py"
    },
    {
      "src": "/api/products/(.*)",
      "dest": "backend/server.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/server.py"
    }
  ]
}
